# Required — app will fail to boot without these (see src/lib/env.ts).
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# Emails (MX reminders, invites, service-event notifications).
RESEND_API_KEY=

# Shared secret between Vercel Cron and /api/cron/* routes.
CRON_SECRET=

# Howard uses Anthropic (Claude Haiku 4.5); Tavily for web search
# fallback; OpenAI for document embeddings.
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
OPENAI_API_KEY=

# Optional — observability. Absent = Sentry no-ops (app runs fine).
# NEXT_PUBLIC_SENTRY_DSN lives on the client bundle; SENTRY_DSN is
# server-only. Use the same value unless you split projects.
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# FAA NMS (NOTAM Management Service) API — required for Howard's
# get_notams tool. KEY/SECRET come from the NMS onboarding spreadsheet
# (separate password-protected email from 7-AWA-NAIMES@faa.gov).
# Auth flow: OAuth2 client credentials → bearer token cached in-memory.
FAA_NMS_CLIENT_ID=
FAA_NMS_CLIENT_SECRET=
# Defaults to staging (https://api-staging.cgifederal-aim.com). Set
# to https://api-nms.aim.faa.gov for production after FAA prod
# onboarding completes (call 866-466-1336 or email 7-AWA-NAIMES@faa.gov).
FAA_NMS_BASE_URL=

# Optional — override the FAA DRS feed endpoint if the default
# https://drs.faa.gov/api/public/search/ads stops returning JSON.
FAA_DRS_FEED_URL=
