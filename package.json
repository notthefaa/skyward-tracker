{
  "name": "skyward-tracker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "vitest run && next build",
    "start": "next start",
    "test": "vitest run",
    "e2e": "docker run --rm --network host -v $PWD:/work -w /work --env-file .env.local -e CI=$CI mcr.microsoft.com/playwright:v1.59.1-noble npx playwright test",
    "e2e:ui": "docker run --rm --network host -v $PWD:/work -w /work --env-file .env.local -p 9323:9323 mcr.microsoft.com/playwright:v1.59.1-noble npx playwright test --ui-port=9323 --ui-host=0.0.0.0",
    "e2e:report": "npx playwright show-report"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.88.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@sentry/nextjs": "^10.48.0",
    "@supabase/ssr": "^0.10.3",
    "@supabase/supabase-js": "^2.39.0",
    "@tavily/core": "^0.7.2",
    "browser-image-compression": "^2.0.2",
    "clsx": "^2.1.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.300.0",
    "next": "^16.1.6",
    "openai": "^6.34.0",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "prop-types": "^15.8.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-image-crop": "^11.0.10",
    "react-markdown": "^10.1.0",
    "react-signature-canvas": "^1.1.0-alpha.2",
    "remark-gfm": "^4.0.1",
    "resend": "^6.9.4",
    "swr": "^2.4.1",
    "tailwind-merge": "^2.2.0"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-signature-canvas": "^1.0.7",
    "postcss": "^8",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.8",
    "vitest": "^4.1.2"
  }
}
